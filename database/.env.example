# MongoDB Configuration for Database Scripts
MONGO_USER=your_username
MONGO_PASS=your_password
MONGO_HOST=your_cluster.mongodb.net
DB_NAME=lesociety

# OR use full connection string
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/lesociety

# BSON Directory (for restore script)
BSON_DIR=/path/to/database/lesociety
